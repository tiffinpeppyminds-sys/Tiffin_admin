rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == "super_admin";
    }

    function isAdminOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    // Production-grade: only Super Admin can create/update/delete admin accounts.
    // Admin can read only their own profile; Super Admin can read all.
    match /adminAccounts/{adminId} {
      allow read: if isSuperAdmin() || isAdminOwner(adminId);
      allow create, update, delete: if isSuperAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
