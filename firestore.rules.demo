rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo mode rules (for local/test auth flows only).
    // Not for production.
    match /adminAccounts/{adminId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
